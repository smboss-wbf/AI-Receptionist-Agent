# ─── LiveKit ──────────────────────────────────────────────────────────────────
# Self-hosted via Docker (default)
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=your-livekit-key-min-32-chars
LIVEKIT_API_SECRET=your-livekit-secret-min-32-chars

# ─── AI Providers ─────────────────────────────────────────────────────────────
# OpenAI — LLM brain
# Get from: platform.openai.com
OPENAI_API_KEY=sk-your-openai-key

# Sarvam AI — Indian STT + TTS
# Get from: dashboard.sarvam.ai
SARVAM_API_KEY=your-sarvam-key

# ─── MCP Server ───────────────────────────────────────────────────────────────
# In Docker: uses container name
MCP_URL=http://mcp-server:9000/sse
# Local dev: use localhost
# MCP_URL=http://localhost:9000/sse

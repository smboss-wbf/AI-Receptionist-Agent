# LiveKit Cloud (or self-hosted) — get from https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# OpenAI — used for the LLM (gpt-4o)
OPENAI_API_KEY=sk-...

# Sarvam AI — used for STT (saaras:v3) and TTS (bulbul:v3)
SARVAM_API_KEY=sk-...
